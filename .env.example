# Server
PORT=3000
NODE_ENV=development

# Database (used by node-pg-migrate and pg Pool)
DATABASE_URL=postgres://app:secret@postgres:5432/github_notifier

# GitHub
GITHUB_TOKEN=              # Optional — increases rate limit to 5000 req/hr

# Redis (optional — caching disabled if not set)
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# Scanner
SCAN_INTERVAL_MS=300000    # 5 minutes

# App
BASE_URL=http://localhost:3000   # Used in confirmation/unsubscribe email links
